<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Socico App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://kit.fontawesome.com/3591f6ace4.js" crossorigin="anonymous"></script>

    <link rel="stylesheet" href="../stylesheets/index.css">
</head>

<body>
    <div class="w-full min-h-screen ">
        <div class="w-full min-h-screen bg-gradient-to-br from-zinc-500 to-zinc-900 flex justify-center items-center ">
            <div class="w-full max-w-5xl  h-auto bg-gradient-to-br from-zinc-800 to-zinc-700 overflow-hidden rounded-2xl border border-2 shadow-lg flex flex-wrap ">
                 <div class="w-full md:w-[50%] bg-transparent p-2 slide-left"> <!--left side -->
                    <hr>
                    <div class="flex justify-center mt-3 flex-col items-center">
                        <h4 class="text-4xl mt-2 text-white font-bold">Register / Sign Up </h4>
                        <div class="relative w-52 h-52 mt-5">
  <!-- Strong gradient shadow layer -->
  <div class="absolute inset-[-15px] rounded-full blur-[8px] opacity-30 z-0"
       style="background: radial-gradient(circle at center, #bebebe, #1b1a1b);">
  </div>

  <!-- Image with circular crop -->
  <div class="w-52 h-52 rounded-full bg-zinc-800 flex justify-center items-center border-2 border-zinc-900 p-2 mb-4 z-10 overflow">
            <i class="fa-solid fa-user text-white text-8xl "></i>
        </div>
</div>

                        <div class="btn-user text-4xl w-44 h-12 bg-transparent mt-8 border-2 border items-center justify-center flex text-white rounded-md ">User</div>
                    </div>
                    <hr class="mt-10">
                    <div class="mt-7 flex gap-1 items-center justify-center">
                        <h3 class="text-2xl text-gray-100 px-4">Do you have an account?</h3>
                        <a href="/login" class="px-5 py-1 text-2xl border border-2 bg-blue-200 rounded-2xl">Login</a>
                    </div>
                </div>
                <div class="w-full md:w-[50%] bg-gradient-to-br from-zinc-700 to-black shadow-xl p-2 slide-right"><!--right side -->
                    <hr>
                    <div class="flex justify-center mt-3 flex-col items-center p-10">
                        <h4 class="text-5xl mb-7 text-white">Fill to Register</h4>
                        <div class="mt-5 w-full">
                            <form action="/register" method="post" class="flex justify-center flex-col ">
                                <input class="px-5 py-2 bg-zinc-900 mb-2 text-white outline-none border border-1 rounded-xl text-2xl" required placeholder="Username" type="text" name="username">
                                <input class="px-5 py-2 bg-zinc-900 mb-2 text-white outline-none border border-1 rounded-xl text-2xl" required placeholder="Email" type="email" name="email">
                                <input class="px-5 py-2 bg-zinc-900 mb-2 text-white outline-none border border-1 rounded-xl text-2xl" required placeholder="Age" type="number" name="age">
                                <input class="px-5 py-2 bg-zinc-900 mb-2 text-white outline-none border border-1 rounded-xl text-2xl" required placeholder="Password" type="password" name="password">
                                <p class="text-red-500 text-xl hidden" id="pass">password must be min 8 character</p>
                                <input class="px-3 py-2 bg-blue-700 mt-7 rounded-3xl text-2xl text-white submit" type="submit" value="Register">
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
