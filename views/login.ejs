<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login Page</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="../stylesheets/style.css">
  <link rel="stylesheet" href="../stylesheets/index.css">
  <script src="https://kit.fontawesome.com/3591f6ace4.js" crossorigin="anonymous"></script>
</head>
<body>
  <div class="flex items-center justify-center w-full min-h-screen bg-gradient-to-br from-zinc-500 to-zinc-900 px-3">
    <div class="max-w-xl min-h-1/2 w-full  text-white bg-gradient-to-br border border-1 border-zinc-500 from-zinc-700 to-black slide-top px-7 py-4 rounded-lg shadow-lg text-center flex justify-center items-center gap-7 flex-wrap ">
       <div class="w-48 h-48  rounded-full overflow-hidden z-10 ">
    <img class="w-full h-full object-cover slide-left shadow-lg" style="background: radial-gradient(circle at center, #bebebe, #1b1a1b);" src="./images/assets/defult.png" alt="">
  </div>
      
      <form action="/login" method="post">
        <div class="flex gap-3 flex-col mt-2 p-4 align-center w-full slide-right">
          <h2 class="text-5xl font-bold mb-5">Login</h2>
        <input id="username" class="px-7 py-2 w-full bg-zinc-200 bg-zinc-800 border border-1 border-zinc-500 text-white rounded-md outline-none text-xl" type="email" placeholder="Email" name="email">
        <input id="password" class="px-7 py-2 w-full bg-zinc-200 bg-zinc-800 border border-1 border-zinc-500 text-white rounded-md outline-none mb-6 text-xl" type="password" placeholder="Password" name="password">
        <input id="submit" class="px-2 py-2 bg-blue-600 w-[60%] m-auto rounded-md text-2xl" type="submit" value="Login">
        <h2 class="text-xl text-zinc-200">Not sigin then <a href="/" class="px-2 py-1 bg-blue-900 rounded-md text-xl">Signup</a></h2>
        </div>
      </form>
    </div>
  </div>
  <!-- <script src="./javascripts/login.js"></script> -->
</body>
</html>
