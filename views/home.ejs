<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Document</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://kit.fontawesome.com/3591f6ace4.js" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="../stylesheets/style.css">
  <link rel="stylesheet" href="./stylesheets/home.css">
</head>

<body class="">
  <div class="w-full min-h-screen bg-zinc-800">
    <div class="w-full fixed top-0 left-0 z-50 glass-l flex items-center justify-between px-10 py-4 ">
      <div class="flex items-center gap-6">
        <div class="flex items-center gap-2">
          <i class="fa-solid fa-user-group text-2xl text-zinc-200 custom-icon"></i>
          <h1 class="text-3xl text-white ">Socico</h1>
        </div>
        <a href="/profile" class="relative">
          <i class="fa-regular fa-circle-user text-4xl text-zinc-200 "></i>
        </a>
      </div>
      <div class="icon w-full flex justify-evenly items-center">
        <a href="/home" class="relative">
          <i class="fa-solid fa-house text-2xl text-zinc-200 "></i>
        </a>
        <a href="/friends" class="relative">
          <i class="fa-solid fa-user-group text-2xl text-zinc-200 custom-icon"></i>
        </a>
      </div>
      <div><a href="/logout" class="text-2xl text-white bg-red-500 px-2 py-1 rounded-lg">Logout</a></div>
    </div>

    <!-- body -->
    <div class="max-w-4xl min-h-screen px-2 py-20 bg-zinc-900 m-auto ">
      <div class="max-w-full mt-1 bg-zinc-800 rounded-lg py-3">
        <div class="flex gap-2 items-center px-3">
          <div class="w-16 h-16 rounded-full overflow-hidden">
            <img class="w-full h-full object-cover" src="/images/assets/<%= user.profilepic %>" alt="">
          </div>
          <div class="mt-2 mb-3 ml-3">
            <h1 class="text-3xl text-white">Hello, <%=user.username%> 👋 </h1>
          </div>
        </div>
        <div class=" max-w-xl px-4 py-2 text-white border border-2 border-zinc-800  rounded-md mb-1 flex ">
          <!-- form sec -->
          <div class="w-full">
            <form action="/post" method="post">
              <textarea required
                class="w-[100%] mb-2 block resize-none bg-transparent border-2 border-zinc-700 rounded-md outline-none p-3"
                placeholder="What's on your mind ..." name="content" id=""></textarea>
              <div class="flex gap-2 flex-wrap">
                <button type="submit"
                  class="flex items-center justify-between gap-2 px-7 py-2 rounded-lg bg-blue-500 mt-1 text-white">
                  Post
                  <i class="fa-solid fa-paper-plane"></i>
                </button>

                <button
                  class="flex items-center justify-between gap-2 px-7 py-2 rounded-lg bg-green-500 mt-1 text-white">
                  <i class="fa-regular fa-images text-2xl"></i>
                  <a href="/profile/photo"> Photos/Video</a>
                </button>

                <button type="submit"
                  class="flex items-center justify-between gap-2 px-7 py-2 rounded-lg bg-yellow-500 mt-1 text-white">
                  <i class="fa-regular fa-user text-xl"></i>
                  <a href="/profile">Upload profile pic</a>
                </button>
              </div>
            </form>
          </div>
        </div>

      </div>
      <!-- posts -->
      <div class="w-full flex flex-col items-center mt-2 gap-y-2 px-2">
        <% posts.forEach(function(post) { %>
          <div class="w-full max-w-[600px] bg-zinc-800 px-6 py-4 rounded-lg text-white">
            <div class="flex gap-2 items-center">
              <div class="w-12 h-12 rounded-full overflow-hidden">
                <img class="w-full h-full object-cover" src=" /images/assets/<%= post.user.profilepic %>" alt="">
              </div>
              <div class="flex flex-col px-2">
                <h4 class="text-red-500 underline">@ <%= post.user.username %>
                </h4>
                <small class="text-zinc-400">
                  <%= post.formattedTime %>
                </small>
              </div>
            </div>
            <p class="px-3 mt-3">
              <%= post.content %>
            </p>
            <% if (post.photos && post.photos.length > 0) { %>
  <% post.photos.forEach(photo => { %>
    <div class="w-48 h-54 rounded-md overflow-hidden mt-3">
      <img class="w-full h-full object-cover rounded-md" src="/images/assets/<%= photo %>" alt="">
    </div>
  <% }) %>
<% } %>


                    <div class="mt-1">
                      <button class="px-3 py-2 rounded-lg bg-transparent  text-white" id="btn-like">
                        <small class="text-red-300 inline-block mt-4">
                          <%= post.likes.length %> likes
                        </small>
                        <i class="fa-regular fa-thumbs-up " id="normal-like"></i>
                        <i class="fa-solid fa-thumbs-up hidden" id="bold-like"></i>
                        <a class="text-blue-500" href="/like/<%= post._id %>">
                          <% if(post.likes.indexOf(user._id)===-1 ) { %>
                            like
                            <% } else{ %>
                              unlike
                              <% } %>
                        </a>

                      </button>
                    </div>
          </div>
          <% }) %>
      </div>




    </div>
  </div>
  <script>
    let normal = document.getElementById("normal-like");
    let boldlike = document.getElementById("bold-like");
    let btnlike = document.getElementById("btn-like");
    btnlike.addEventListener('click', function () {

      normal.style.display = 'none'
      boldlike.style.display = 'inline-block'
    })

  </script>
</body>

</html>